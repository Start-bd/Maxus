# =============================================
# Manus Agent System - Environment Variables
# Copy this file to .env and fill in values
# =============================================

# Application
APP_NAME="Manus Agent System"
DEBUG=false
ENVIRONMENT=production

# LLM Provider
# Options: "openai" or "anthropic"
LLM_PROVIDER=openai
LLM_MODEL=gpt-3.5-turbo
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.7

# API Keys (set at least one)
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here

# NewsAPI key for fetching real news
NEWS_API_KEY=your-newsapi-key-here

# Database
# For Vercel: use sqlite:////tmp/manus_agent.db
# For local: use sqlite:///./manus_agent.db
# For production: use postgresql://user:pass@host/dbname
DATABASE_URL=sqlite:///./manus_agent.db

# Redis (optional - for Celery background tasks)
# Not required on Vercel serverless
REDIS_URL=redis://localhost:6379/0

# CORS (comma-separated origins, or * for all)
ALLOWED_ORIGINS=["*"]
